{
  "name": "icd-networkviz",
  "version": "1.0.0",
  "description": "Interactive visualization of ICD-10 medical diagnosis codes using D3.js",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "lint": "eslint src --ext .ts,.tsx",
    "typecheck": "tsc --noEmit",
    "build:details": "node scripts/build-icd10-details.mjs"
  },
  "devDependencies": {
    "@types/d3": "^7.4.3",
    "fast-xml-parser": "^5.6.0",
    "typescript": "^5.4.0",
    "vite": "^8.0.5"
  },
  "dependencies": {
    "d3": "^7.9.0"
  }
}
